@page "/login"
@layout MainLayout
@inject NavigationManager Nav
@inject IJSRuntime JS
@rendermode InteractiveServer

<PageTitle>@L["LoginPageTitle"]</PageTitle>

<div class="login-container">
    <div class="login-card">
        <h2>@L["AppName"]</h2>
        <form @onsubmit="HandleLogin">
            <input type="password" @bind="_password" placeholder="@L["EnterAccessKey"]"
                   class="login-input" autocomplete="current-password" disabled="@_loading" />
            <button type="submit" class="login-button" disabled="@_loading">
                @if (_loading)
                {
                    <span>...</span>
                }
                else
                {
                    <span>@L["EnterButton"]</span>
                }
            </button>
        </form>
        @if (!string.IsNullOrEmpty(_error))
        {
            <div class="login-error">@_error</div>
        }
    </div>
</div>

@code {
    private string _password = string.Empty;
    private string _error = string.Empty;
    private bool _loading;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("monitorAuth.setTranslations", new
            {
                accessDenied = L["AccessDenied"].Value,
                connectionError = L["ConnectionErrorTryAgain"].Value
            });
        }
    }

    private async Task HandleLogin()
    {
        if (_loading) return;
        _loading = true;
        _error = string.Empty;

        try
        {
            var result = await JS.InvokeAsync<LoginResult>("monitorAuth.login", _password);
            if (result.Success)
            {
                Nav.NavigateTo("/", forceLoad: true);
            }
            else
            {
                _error = result.Message ?? L["AccessDenied"].Value;
                _password = string.Empty;
            }
        }
        catch
        {
            _error = L["ConnectionErrorTryAgain"].Value;
        }
        finally
        {
            _loading = false;
        }
    }

    private sealed class LoginResult
    {
        public bool Success { get; set; }
        public string? Message { get; set; }
    }
}
