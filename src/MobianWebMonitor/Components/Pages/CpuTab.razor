@namespace MobianWebMonitor.Components
@inject IJSRuntime JS

<div class="chart-tab">
    <div class="chart-controls">
        <select @onchange="OnRangeChanged" class="range-select">
            <option value="5m" selected="@(_range == "5m")">@L["FiveMinutes"]</option>
            <option value="15m" selected="@(_range == "15m")">@L["FifteenMinutes"]</option>
            <option value="1h" selected="@(_range == "1h")">@L["OneHour"]</option>
            <option value="6h" selected="@(_range == "6h")">@L["SixHours"]</option>
            <option value="24h" selected="@(_range == "24h")">@L["TwentyFourHours"]</option>
        </select>
    </div>
    <div class="chart-wrapper">
        <canvas id="cpuChart"></canvas>
    </div>

    <div class="chart-live-values">
        <div class="live-value">
            <span class="live-label">@L["Total"]</span>
            <span class="live-number">@Snapshot.Cpu.TotalUsagePercent.ToString("F1")%</span>
        </div>
        @for (int i = 0; i < Snapshot.Cpu.CoreUsagePercents.Count; i++)
        {
            var idx = i;
            <div class="live-value">
                <span class="live-label">@L["CoreWithIndex", idx]</span>
                <span class="live-number">@Snapshot.Cpu.CoreUsagePercents[idx].ToString("F1")%</span>
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public MetricsSnapshot Snapshot { get; set; } = new();

    private string _range = "5m";
    private bool _chartInitialized;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender || !_chartInitialized)
        {
            _chartInitialized = true;
            await LoadChartData();
        }

        if (_chartInitialized)
        {
            await JS.InvokeVoidAsync("chartInterop.addCpuPoint",
                Snapshot.TimestampUtc.ToString("o"),
                Snapshot.Cpu.TotalUsagePercent,
                Snapshot.Cpu.CoreUsagePercents.ToArray());
        }
    }

    private async Task OnRangeChanged(ChangeEventArgs e)
    {
        _range = e.Value?.ToString() ?? "5m";
        await LoadChartData();
    }

    private async Task LoadChartData()
    {
        try
        {
            var coreLabels = Enumerable.Range(0, Snapshot.Cpu.CoreUsagePercents.Count)
                .Select(i => L["CoreWithIndex", i].Value)
                .ToArray();

            await JS.InvokeVoidAsync("chartInterop.initCpuChart", "cpuChart", _range,
                Snapshot.Cpu.CoreUsagePercents.Count,
                L["Total"].Value,
                coreLabels);
        }
        catch
        {
            // Chart.js not loaded yet
        }
    }
}
