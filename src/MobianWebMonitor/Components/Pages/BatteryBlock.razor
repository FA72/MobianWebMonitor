@namespace MobianWebMonitor.Components

<div class="battery-block">
    <div class="battery-header">
        <div class="battery-icon">
            @{
                var pct = Battery.CapacityPercent ?? 0;
                var color = pct > 60 ? "#4caf50" : pct > 20 ? "#ff9800" : "#f44336";
            }
            <svg width="32" height="18" viewBox="0 0 32 18">
                <rect x="1" y="1" width="26" height="16" rx="2" fill="none" stroke="#888" stroke-width="1.5"/>
                <rect x="27" y="5" width="3" height="8" rx="1" fill="#888"/>
                <rect x="3" y="3" width="@(22 * pct / 100)" height="12" rx="1" fill="@color"/>
            </svg>
        </div>
        <span class="battery-percent" style="color: @color">@FormatCapacity(Battery.CapacityPercent)</span>
        <span class="battery-status">@FormatBatteryStatus()</span>
        @if (Battery.ExternalPowered == true)
        {
            <span class="battery-plugged">⚡</span>
        }
    </div>
    <div class="battery-details">
        <div class="battery-detail">
            <span class="label">@L["Temperature"]</span>
            <span class="value">@FormatTemperature(Battery.TemperatureCelsius)</span>
        </div>
        <div class="battery-detail">
            <span class="label">@L["Current"]</span>
            <span class="value">@FormatCurrent(Battery.CurrentMicroAmps)</span>
        </div>
        <div class="battery-detail">
            <span class="label">@L["Voltage"]</span>
            <span class="value">@FormatVoltage(Battery.VoltageMicroVolts)</span>
        </div>
        <div class="battery-detail">
            <span class="label">@L["Health"]</span>
            <span class="value">@FormatHealth(Battery.Health)</span>
        </div>
        <div class="battery-detail">
            <span class="label">@L["Limiter"]</span>
            <span class="value limiter-@(Battery.BatteryLimiterStatus?.ToLowerInvariant() ?? "na")">
                @FormatServiceState(Battery.BatteryLimiterStatus)
            </span>
        </div>
    </div>
</div>

@code {
    [Parameter] public BatteryInfo Battery { get; set; } = new();

    private string FormatCapacity(int? capacityPercent) =>
        capacityPercent.HasValue ? $"{capacityPercent.Value}%" : L["NotAvailable"].Value;

    private string FormatTemperature(double? celsius) =>
        celsius.HasValue ? $"{celsius.Value:F1}°C" : L["NotAvailable"].Value;

    private string FormatCurrent(int? microAmps) =>
        microAmps.HasValue ? $"{microAmps.Value / 1000.0:F0} mA" : L["NotAvailable"].Value;

    private string FormatVoltage(int? microVolts) =>
        microVolts.HasValue ? $"{microVolts.Value / 1_000_000.0:F2} V" : L["NotAvailable"].Value;

    private string FormatBatteryStatus()
    {
        var value = Battery.Status ?? Battery.ChargeStatus;
        return value?.ToLowerInvariant() switch
        {
            "charging" => L["Charging"],
            "discharging" => L["Discharging"],
            "full" => L["Full"],
            "not charging" => L["NotCharging"],
            _ when string.IsNullOrWhiteSpace(value) => L["NotAvailable"],
            _ => value
        };
    }

    private string FormatHealth(string? value) =>
        value?.ToLowerInvariant() switch
        {
            "good" => L["Good"],
            "unknown" => L["Unknown"],
            _ when string.IsNullOrWhiteSpace(value) => L["NotAvailable"],
            _ => value
        };

    private string FormatServiceState(string? value) =>
        value?.ToLowerInvariant() switch
        {
            "active" => L["Active"],
            "inactive" => L["Inactive"],
            "failed" => L["Failed"],
            "running" => L["Running"],
            "dead" => L["Dead"],
            "starting" => L["Starting"],
            _ when string.IsNullOrWhiteSpace(value) => L["NotAvailable"],
            _ => value
        };
}
