{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "MobianWebMonitor.Metrics": "Information",
      "MobianWebMonitor.Storage": "Information"
    }
  },
  "AllowedHosts": "*",
  "HostPaths": {
    "ProcRoot": "/proc",
    "SysRoot": "/sys"
  },
  "Auth": {
    "PasswordHash": "",
    "MaxFailedAttempts": 5,
    "LockoutMinutes": 15
  },
  "Urls": "http://0.0.0.0:8082"
}
